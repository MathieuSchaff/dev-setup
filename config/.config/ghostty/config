# Config Tuxedo/KDE (Wayland)
window-decoration = client
linux-cgroup = never

# Apparence
theme = Catppuccin Macchiato
font-family = JetBrainsMono Nerd Font
font-size = 13
window-padding-x = 12
window-padding-y = 10
background-opacity = 0.97
background-blur-radius = 10
cursor-style = block
cursor-style-blink = false

# Comportement
bell-features = no-system,no-audio,no-attention,no-title,no-border
# copy-on-select = clipboard
# Disabled: let tmux handle mouse selection, avoids double-click focus delay
copy-on-select = false
mouse-hide-while-typing = true
confirm-close-surface = false
scrollback-limit = 100000
window-save-state = always

# Keybinds
keybind = ctrl+shift+d=toggle_window_decorations
