{
    // ──────────────────────────────────────────────────────────────
    //  Interface et Thème (gardé tel quel)
    // ──────────────────────────────────────────────────────────────
    "theme": {
        "mode": "dark",
        "light": "Catppuccin Latte",
        "dark": "Catppuccin Macchiato"
    },
    "icon_theme": {
        "mode": "dark",
        "light": "Zed (Default)",
        "dark": "Catppuccin Macchiato"
    },
    "ui_font_size": 18,
    "buffer_font_size": 18,
    "buffer_font_family": ".ZedMono",
    "centered_layout": {
        "left_padding": 0.2,
        "right_padding": 0.2
    },

    // ──────────────────────────────────────────────────────────────
    //  Éditeur & confort (gardé + quelques ajouts légers 2026)
    // ──────────────────────────────────────────────────────────────
    "vim_mode": true,
    "base_keymap": "VSCode",
    "relative_line_numbers": "enabled",
    "scrollbar": {
        "show": "auto"
    },
    "minimap": {
        "show": "never"
    },
    "gutter": {
        "line_numbers": true,
        "runnables": true,
        "breakpoints": false,
        "folds": true,
        "min_line_number_digits": 0
    },
    "sticky_scroll": {
        "enabled": false
    },
    "indent_guides": {
        "enabled": false
    },
    "show_whitespaces": "none",

    // ──────────────────────────────────────────────────────────────
    //  Panneaux
    // ──────────────────────────────────────────────────────────────
    "project_panel": {
        "indent_size": 15.0,
        "entry_spacing": "comfortable",
        "dock": "right"
    },

    // ──────────────────────────────────────────────────────────────
    //  Format & code actions global (activé partout)
    // ──────────────────────────────────────────────────────────────
    "format_on_save": "on",
    "code_actions_on_format": {
        "source.fixAll.biome": true,
        "source.organizeImports.biome": true
    },

    // ──────────────────────────────────────────────────────────────
    //  TypeScript / TSX ─ Biome + vtsls (combo très courant 2026)
    // ──────────────────────────────────────────────────────────────
    "languages": {
        "TypeScript": {
            "language_servers": [
                "vtsls", // principal : diagnostics TS, navigation, inlay hints, etc.
                "biome", // lint + organize imports + format
                "!typescript-language-server", // on vire l'ancien tsserver pour éviter les conflits
                "!eslint" // on vire eslint si tu utilises Biome
            ],
            "formatter": {
                "language_server": {
                    "name": "biome",
                    "settings": {
                        "formatter": {
                            "formatWithErrors": true
                        },
                        "organizeImports": {
                            "enabled": true
                        }
                    }
                }
            },
            "code_actions_on_format": {
                "source.fixAll.biome": true,
                "source.organizeImports.biome": true
            }
        },

        "TSX": {
            "language_servers": [
                "vtsls",
                "biome",
                "!typescript-language-server",
                "!eslint"
            ],
            "formatter": {
                "language_server": {
                    "name": "biome",
                    "settings": {
                        "formatter": {
                            "formatWithErrors": true
                        },
                        "organizeImports": {
                            "enabled": true
                        }
                    }
                }
            },
            "code_actions_on_format": {
                "source.fixAll.biome": true,
                "source.organizeImports.biome": true
            }
        },

        "JavaScript": {
            "language_servers": [
                "vtsls",
                "biome",
                "!typescript-language-server",
                "!eslint"
            ],
            "formatter": {
                "language_server": {
                    "name": "biome",
                    "settings": {
                        "formatter": {
                            "formatWithErrors": true
                        },
                        "organizeImports": {
                            "enabled": true
                        }
                    }
                }
            },
            "code_actions_on_format": {
                "source.fixAll.biome": true,
                "source.organizeImports.biome": true
            }
        },

        "JSX": {
            "language_servers": [
                "vtsls",
                "biome",
                "!typescript-language-server",
                "!eslint"
            ],
            "formatter": {
                "language_server": {
                    "name": "biome",
                    "settings": {
                        "formatter": {
                            "formatWithErrors": true
                        },
                        "organizeImports": {
                            "enabled": true
                        }
                    }
                }
            },
            "code_actions_on_format": {
                "source.fixAll.biome": true,
                "source.organizeImports.biome": true
            }
        }
    },
    // ──────────────────────────────────────────────────────────────
    //  Configuration fine de vtsls (léger tuning)
    // ──────────────────────────────────────────────────────────────
    "lsp": {
        "vtsls": {
            "settings": {
                "vtsls": {
                    "autoUseWorkspaceTsdk": true, // utilise le tsserver du projet (tsconfig/plugins locaux)
                    "enableMoveToFileCodeAction": true // refactor: move to file plus fluide
                },
                "typescript": {
                    "tsserver": {
                        "maxTsServerMemory": 4096,
                        "useSyntaxServer": "auto",
                        "experimental": {
                            "enableProjectDiagnostics": false
                        }
                    },
                    "preferences": {
                        "importModuleSpecifier": "non-relative", // imports absolus / non-relatifs quand possible
                        "importModuleSpecifierEnding": "minimal" // enlève les extensions inutiles (.js, etc.)
                    },
                    "updateImportsOnFileMove": {
                        "enabled": "always" // met à jour les imports auto quand tu déplaces/renommes un fichier
                    }
                },
                "javascript": {
                    "preferences": {
                        "importModuleSpecifier": "non-relative",
                        "importModuleSpecifierEnding": "minimal"
                    }
                }
            }
        },

        "biome": {
            "settings": {
                "require_config_file": true, // Biome ne se lance QUE si biome.json(c) existe (ton cas)
                "formatter": {
                    "formatWithErrors": true // permet format même avec erreurs de parsing (code en cours)
                },
                "organizeImports": {
                    "enabled": true // organise imports au save (via code_actions)
                }
            }
        }
    },

    // ──────────────────────────────────────────────────────────────
    //  Exclusions scan (gardé, très utile)
    // ──────────────────────────────────────────────────────────────
    "file_scan_exclusions": [
        "**/node_modules/**",
        "**/dist/**",
        "**/.turbo/**",
        "**/*.tsbuildinfo",
        "**/routeTree.gen.ts",
        "**/.git",
        "**/.svn",
        "**/.hg",
        "**/CVS",
        "**/.DS_Store",
        "**/Thumbs.db",
        "**/.classpath",
        "**/.settings",
        // above is default from Zed
        "**/out",
        "**/.husky",
        "**/.vscode-test",
        "**/.vscode",
        "**/.next",
        "**/.storybook",
        "**/.tap",
        "**/.nyc_output",
        "**/report",
        "**/*.d.ts.map"
    ],
    "directory_relationships": {
        "**/dist/**": "hidden",
        "**/*.d.ts": "hidden",
        "**/*.d.ts.map": "hidden",
        "**/*.tsbuildinfo": "hidden"
    },
    // ──────────────────────────────────────────────────────────────
    //  IA / Ollama ─ gardé tel quel
    // ──────────────────────────────────────────────────────────────
    "disable_ai": false,
    "language_models": {
        "ollama": {
            "api_url": "http://localhost:11434",
            "available_models": [
                {
                    "name": "qwen2.5-coder:7b-instruct-q4_K_M",
                    "display_name": "Qwen Coder 7B",
                    "max_tokens": 8192
                },
                {
                    "name": "deepseek-coder-v2:16b-lite-instruct-q4_K_M",
                    "display_name": "DeepSeek Coder 16B",
                    "max_tokens": 8192
                }
            ]
        }
    },
    "agent": {
        "default_model": {
            "provider": "ollama",
            "model": "qwen2.5-coder:7b-instruct-q4_K_M"
        }
    },
    "edit_predictions": {
        "provider": "ollama",
        "ollama": {
            "model": "qwen2.5-coder:7b-instruct-q4_K_M"
        }
    },
    "show_edit_predictions": false
}
