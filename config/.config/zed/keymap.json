[
    // ============================================================
    // VIM VISUAL
    // ============================================================
    {
        "context": "vim_mode == visual",
        "bindings": {
            "shift-s": "vim::PushAddSurrounds",
            "space c": "editor::ToggleComments",
            "ctrl-a": "workspace::ToggleLeftDock",
            "ctrl-,": "project_symbols::Toggle",
            "ctrl-;": "pane::DeploySearch",
            "ctrl-q": "buffer_search::DeployReplace",
            "ctrl-h": "pane::ActivatePreviousItem",
            "ctrl-l": "pane::ActivateNextItem",
            "ctrl-j": "workspace::ActivatePaneLeft",
            "ctrl-k": "workspace::ActivatePaneRight",
            "ctrl-n": "editor::GoToDiagnostic",
            "ctrl-p": "editor::GoToPreviousDiagnostic",
            // Resize panes (Direct keys)
            "é": "vim::ResizePaneLeft",
            "è": "vim::ResizePaneRight",
            "ç": "vim::ResizePaneUp",
            "à": "vim::ResizePaneDown",
            // Reset and Rewrap
            "ctrl-t": "vim::ResetPaneSizes",
            "g q": "vim::Rewrap",
            "alt-f": "vim::Rewrap",
            // Global Toggles
            "²": "terminal_panel::Toggle"
        }
    },
    // ============================================================
    // VIM INSERT
    // ============================================================
    {
        "context": "vim_mode == insert",
        "bindings": {
            "ctrl-a": "workspace::ToggleLeftDock",
            "ctrl-,": "project_symbols::Toggle",
            "ctrl-;": "pane::DeploySearch",
            "ctrl-q": "buffer_search::DeployReplace",
            "ctrl-h": "pane::ActivatePreviousItem",
            "ctrl-l": "pane::ActivateNextItem",
            "ctrl-j": "workspace::ActivatePaneLeft",
            "ctrl-k": "workspace::ActivatePaneRight"
        }
    },
    // ============================================================
    // VIM NORMAL
    // ============================================================
    {
        "context": "vim_mode == normal",
        "bindings": {
            // Commenter
            "space c": "editor::ToggleComments",
            // Navigation méthodes
            "g n": "vim::NextMethodStart",
            "g p": "vim::PreviousMethodStart",
            // Navigation diagnostics
            "ctrl-a": "workspace::ToggleLeftDock",
            "ctrl-,": "project_symbols::Toggle",
            "ctrl-;": "pane::DeploySearch",
            "ctrl-q": "buffer_search::DeployReplace",
            "ctrl-h": "pane::ActivatePreviousItem",
            "ctrl-l": "pane::ActivateNextItem",
            "ctrl-j": "workspace::ActivatePaneLeft",
            "ctrl-k": "workspace::ActivatePaneRight",
            "ctrl-n": "editor::GoToDiagnostic",
            "ctrl-p": "editor::GoToPreviousDiagnostic",
            // LSP
            "g i": "editor::GoToImplementation",
            "space l r": "editor::Rename",
            "space l f": "editor::Format",
            "&": "editor::ToggleCodeActions",
            // File tree
            "space e": "workspace::ToggleRightDock",
            "space o": "project_panel::ToggleFocus",
            // Recherche
            "?": "file_finder::Toggle",
            // AZERTY: shift-; would otherwise trigger vim : (QWERTY assumption)
            "shift-;": null,
            // AZERTY: § (= shift-! key) — toggle between split panes (cycle)
            "§": "workspace::ActivateNextPane",
            // Git
            "space g t": "git_panel::ToggleFocus",
            // Diagnostics panel
            "space l d": "diagnostics::Deploy",
            // Buffer management
            "space x": "pane::CloseActiveItem",
            "space w": "workspace::Save",
            // Splits
            "space t h": "pane::SplitDown",
            "space t v": "pane::SplitRight",
            "ù": "pane::SplitRight",
            // Resize panes (Direct keys)
            "é": "vim::ResizePaneLeft",
            "è": "vim::ResizePaneRight",
            "ç": "vim::ResizePaneUp",
            "à": "vim::ResizePaneDown",
            // Reset and Rewrap
            "ctrl-t": "vim::ResetPaneSizes",
            "g q": "vim::Rewrap",
            "alt-f": "vim::Rewrap",
            // Global Toggles
            "²": "terminal_panel::Toggle"
        }
    },
    // ============================================================
    // GLOBAL - Workspace
    // ============================================================
    {
        "context": "Workspace",
        "bindings": {
            // Tab nav (prev/next item) — ⚠ ctrl-h conflicts with Zed default search&replace, remap later
            "ctrl-h": "pane::ActivatePreviousItem",
            "ctrl-l": "pane::ActivateNextItem",
            // Pane nav (left/right)
            "ctrl-j": "workspace::ActivatePaneLeft",
            "ctrl-k": "workspace::ActivatePaneRight",
            "ctrl-a": "workspace::ToggleLeftDock",
            "ctrl-,": "project_symbols::Toggle",
            "ctrl-;": "pane::DeploySearch",
            "ctrl-q": "buffer_search::DeployReplace",
            // Resize panes (Legacy combos)
            "ctrl-shift-left": "vim::ResizePaneLeft",
            "ctrl-shift-right": "vim::ResizePaneRight",
            "ctrl-shift-up": "vim::ResizePaneUp",
            "ctrl-shift-down": "vim::ResizePaneDown"
        }
    },
    // ============================================================
    // PROJECT PANEL
    // ============================================================
    {
        "context": "ProjectPanel && not_editing",
        "bindings": {
            "space e": "workspace::ToggleRightDock"
        }
    },
    // ============================================================
    // DOCK
    // ============================================================
    {
        "context": "Dock",
        "bindings": {
            "space e": "workspace::ToggleRightDock"
        }
    }
]
